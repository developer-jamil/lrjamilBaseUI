<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Developed By Jamil Lab LTD -->
    <!-- Global View Styles -->
    <style name="text_view">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_color</item>
        <item name="android:textSize">@dimen/normal_t_size</item>
    </style>

    <style name="normal_text" parent="text_view">
        <item name="android:textColor">@color/text_color</item>
    </style>

    <style name="normal_text_bold" parent="normal_text">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="text_view_medium" parent="text_view">
        <item name="android:textSize">@dimen/text_view_medium_t_size</item>
    </style>

    <style name="text_view_medium_bold" parent="text_view_medium">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="text_view_small" parent="text_view">
        <item name="android:textSize">@dimen/small_t_size</item>
    </style>

    <style name="text_view_small_bold" parent="text_view_small">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="text_view_smallest" parent="text_view">
        <item name="android:textSize">@dimen/smallest_t_size</item>
    </style>

    <style name="text_view_smallest_bold" parent="text_view_smallest">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="header_1" parent="text_view">
        <item name="android:textSize">@dimen/header_1_t_size</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="header_2" parent="header_1">
        <item name="android:textSize">@dimen/header_2_t_size</item>
    </style>

    <style name="header_3" parent="header_1">
        <item name="android:textSize">@dimen/header_3_t_size</item>
    </style>

    <style name="clickable_style">
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>

    <style name="linear_view">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="margin_1" parent="linear_view">
        <item name="android:layout_marginStart">@dimen/_10sdp</item>
        <item name="android:layout_marginEnd">@dimen/_10sdp</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="margin_2" parent="linear_view">
        <item name="android:layout_marginStart">@dimen/_14sdp</item>
        <item name="android:layout_marginEnd">@dimen/_14sdp</item>
        <item name="android:orientation">vertical</item>
    </style>

    <!-- Card and Edit Text Styles -->
    <style name="singleFullCard_EditText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="cardCornerRadius">@dimen/_30sdp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/colorCardBorder</item>
    </style>

    <style name="singleFullBoarderCard_EditText" parent="singleFullCard_EditText">
        <item name="cardBackgroundColor">@color/colorBrand</item>
        <item name="cardCornerRadius">@dimen/_8sdp</item>
    </style>

    <style name="editTextStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">@color/transparent</item>
        <item name="android:inputType">text</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:padding">@dimen/_8sdp</item>
        <item name="android:textAlignment">textStart</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
